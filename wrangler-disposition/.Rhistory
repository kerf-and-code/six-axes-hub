cmdstanr::check_cmdstan_toolchain()   # tells you if a C++ compiler is missing
cmdstanr::install_cmdstan()           # downloads + builds CmdStan, takes a few minutes
cmdstanr::install_cmdstan(overwrite = TRUE)
options(download.file.method = "libcurl", timeout = 1200)
cmdstanr::install_cmdstan(overwrite = TRUE)
cmdstanr::install_cmdstan(release_file = "C:/Users/Test/Downloads/cmdstan-2.39.0.tar.gz", overwrite = TRUE)
suppressPackageStartupMessages({
library(DBI); library(RPostgres); library(jsonlite); library(cmdstanr)
})
## ---- config -------------------------------------------------------------
CAMPAIGN_ID   <- Sys.getenv("WRANGLER_CAMPAIGN_ID")
MODEL_VERSION <- "wrangler-disp-v1.0-nb"
ANSWERS_COL   <- "responses"   # jsonb column in tpdi_responses holding {item_id: 1..5 | "NB"}
AXES          <- c("N", "T", "O", "S", "E", "I")
stopifnot("Set WRANGLER_CAMPAIGN_ID" = nzchar(CAMPAIGN_ID))
## TPDI item -> axis, with reverse flags (matches the instrument: 1-5 Likert,
## reverse item scored as 6 - raw, axis score = mean of its four items).
ITEMS <- do.call(rbind, lapply(AXES, function(ax)
data.frame(id = paste0(tolower(ax), 1:4), axis = ax,
reverse = c(FALSE, FALSE, FALSE, TRUE), stringsAsFactors = FALSE)))
## ---- connect (direct Postgres; bypasses RLS so the write-back works) -----
con <- dbConnect(RPostgres::Postgres(),
host     = Sys.getenv("SUPABASE_DB_HOST"),
port     = as.integer(Sys.getenv("SUPABASE_DB_PORT", "5432")),
dbname   = Sys.getenv("SUPABASE_DB_NAME", "postgres"),
user     = Sys.getenv("SUPABASE_DB_USER"),
password = Sys.getenv("SUPABASE_DB_PASSWORD"),
sslmode  = "require")
cmdstanr::install_cmdstan(release_file = "C:/Users/Test/Downloads/cmdstan-2.39.0.tar.gz", overwrite = TRUE)
